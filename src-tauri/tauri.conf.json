{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mind Arena",
  "version": "0.1.0",
  "identifier": "com.lzr2003.mindarena",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mind Arena",
        "width": 1440,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
